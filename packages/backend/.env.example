# Backend
PORT=3000

# Auth JWT (required)
# Use a long random value (minimum 16 chars).
JWT_SECRET=change_this_with_a_long_random_secret_value
JWT_EXPIRES_IN=1h

# Frontend allowed origin (CORS)
FRONTEND_ORIGIN=http://localhost:4200

# SIWE — debe coincidir con `chainId` del frontend y con la red en MetaMask (Ganache: revisa Network ID en la UI).
SIWE_DOMAIN=localhost:4200
SIWE_URI=http://localhost:4200
SIWE_CHAIN_ID=1337