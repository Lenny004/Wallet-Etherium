# Backend
PORT=3000

# Auth JWT (required)
# Use a long random value (minimum 16 chars).
JWT_SECRET=change_this_with_a_long_random_secret_value
JWT_EXPIRES_IN=1h

# Frontend allowed origin (CORS)
FRONTEND_ORIGIN=http://localhost:4200

# SIWE — debe coincidir con `chainId` del frontend y con el "Network ID" de Ganache (Quickstart suele ser 5777; si ves 1337, úsalo en los tres sitios).
SIWE_DOMAIN=localhost:4200
SIWE_URI=http://localhost:4200
SIWE_CHAIN_ID=5777
# (El backend no lee `SIWE_CHAIN_NAME`; solo `SIWE_CHAIN_ID`.)

# Opcional: misma mnemónica que muestra Ganache (cuenta prefinanciada). Crea un usuario local al arrancar el backend.
# No subas este archivo con una frase real; solo en tu `.env` local.
# GANACHE_MNEMONIC=word1 word2 ... word12
# Cuenta de la lista de Ganache (0 = primera fila). Debe coincidir con la dirección que uses en login.
# GANACHE_ACCOUNT_INDEX=0

# Validación de transferencias (capa Policy) — opcional
# Tope máximo por operación en ETH (cadena decimal). Si no se define, no hay tope.
# MAX_TRANSFER_ETH=10
# Lista de direcciones de destino bloqueadas (separadas por coma).
# TRANSFER_BLOCKED_ADDRESSES=0x0000000000000000000000000000000000000000