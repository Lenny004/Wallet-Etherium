```javascript
// ❌ ANTES — Importacion de libreria completa (bundle: +70KB)
import _ from 'lodash';
const result = _.debounce(handler, 300);

// ✅ DESPUES — Importacion granular (bundle: +2KB)
import debounce from 'lodash-es/debounce';
const result = debounce(handler, 300);

// ❌ ANTES — Ruta cargada estaticamente
import DashboardPage from './pages/Dashboard';

// ✅ DESPUES — Lazy loading con React.lazy
const DashboardPage = React.lazy(() => import('./pages/Dashboard'));
// En el router:
<Suspense fallback={<Spinner />}>
  <DashboardPage />
</Suspense>

// ❌ ANTES — vite.config.ts sin separacion dev/prod
export default defineConfig({ sourcemap: true, minify: false });

// ✅ DESPUES — Configuracion segun entorno
export default defineConfig(({ mode }) => ({
  build: {
    sourcemap: mode === 'development' ? 'inline' : false,
    minify: mode === 'production' ? 'esbuild' : false,
  }
}));
```

