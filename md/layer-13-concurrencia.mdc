```javascript
// ❌ ANTES — Waterfall secuencial (latencia acumulada)
const user    = await db.getUser(id);       // 80ms
const orders  = await db.getOrders(id);     // 60ms
const profile = await db.getProfile(id);   // 70ms
// Total: ~210ms

// ✅ DESPUES — Ejecucion paralela con Promise.all
const [user, orders, profile] = await Promise.all([
  db.getUser(id),
  db.getOrders(id),
  db.getProfile(id),
]);
// Total: ~80ms (duracion del mas lento)

// ❌ ANTES — CPU-bound en hilo principal (bloquea el Event Loop)
app.get('/report', (req, res) => {
  const result = generateHeavyReport(data); // 300ms bloqueantes
  res.json(result);
});

// ✅ DESPUES — Delegacion a Worker Thread
const { Worker } = require('worker_threads');
app.get('/report', (req, res) => {
  const worker = workerPool.acquire();
  worker.postMessage({ type: 'generateReport', data });
  worker.once('message', result => res.json(result));
});
```

