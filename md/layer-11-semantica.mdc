```javascript
// ❌ ANTES — Coercion implicita y guarda falsy incorrecta
function calcularDescuento(precio, descuento) {
  if (descuento) {            // ⚠️ Falla cuando descuento === 0
    return precio - descuento;
  }
  return precio;
}

const total = "100" + calcularDescuento(50, 0); // "10050" por coercion de +

// ✅ DESPUES — Verificacion explicita y tipado seguro
function calcularDescuento(precio: number, descuento: number): number {
  if (descuento != null && Number.isFinite(descuento)) {
    return precio - descuento;
  }
  return precio;
}

const total: number = 100 + calcularDescuento(50, 0); // 150
```

