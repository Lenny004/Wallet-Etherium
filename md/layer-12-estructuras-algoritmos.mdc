```javascript
// ❌ ANTES — Busqueda O(n) repetida en cada request
function getUserById(users, id) {
  return users.find(u => u.id === id); // O(n) en cada llamada
}

// ❌ ANTES — Deduplicacion O(n^2)
const unique = arr.filter((val, idx) => arr.indexOf(val) === idx);

// ✅ DESPUES — Indice preconstruido O(1) por lookup
const userIndex = new Map(users.map(u => [u.id, u])); // O(n) una vez
function getUserById(id) {
  return userIndex.get(id); // O(1)
}

// ✅ DESPUES — Deduplicacion O(n) con Set
const unique = [...new Set(arr)];
```

