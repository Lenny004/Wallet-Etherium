```javascript
// ❌ ANTES — Modelo Anemico: objeto sin comportamiento, logica en el servicio
class Order {
  constructor() { this.status = 'pending'; this.items = []; }
}

class OrderService {
  confirm(order) {
    if (order.items.length === 0) throw new Error('No items'); // Regla en servicio
    order.status = 'confirmed'; // Mutacion directa desde fuera
  }
}

// ✅ DESPUES — Modelo Rico: la entidad protege sus propias invariantes
class Order {
  #status;
  #items;

  constructor() {
    this.#status = OrderStatus.PENDING;
    this.#items  = [];
  }

  confirm() {
    if (this.#items.length === 0) {
      throw new DomainException('Cannot confirm an order with no items.');
    }
    this.#status = OrderStatus.CONFIRMED;
    this.recordEvent(new OrderConfirmed(this.id, new Date())); // Evento de dominio
  }

  get status() { return this.#status; }
}

// ❌ ANTES — Infraestructura en el dominio (TypeORM en la entidad)
@Entity()
class User {
  @Column() email: string;
}

// ✅ DESPUES — Entidad de dominio pura (sin dependencias de ORM)
class User {
  constructor(
    private readonly id: UserId,
    private readonly email: Email,   // Value Object con validacion
  ) {}
}

// Adaptador de infraestructura separado:
@Entity('users')
class UserOrmEntity {
  @Column() email: string;
  toDomain(): User { return new User(new UserId(this.id), new Email(this.email)); }
}
```

